rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // רק המנהל המורשה יכול לקרוא ולכתוב ישירות
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'gal9amar@gmail.com';
    }

    // מוצרים — קריאה ציבורית (דרך Function), כתיבה רק למנהל
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // סקרים — כתיבה ציבורית (מהטופס), קריאה/מחיקה רק למנהל
    match /surveys/{id} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // חשבוניות — כתיבה ציבורית (מהטופס), קריאה/מחיקה רק למנהל
    match /invoices/{id} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if false;
    }
  }
}
